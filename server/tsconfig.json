{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "removeComments": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "files": ["src/types/express.d.ts"]
}
